/*
 * Device tree for Rafael RT584 EVB
 */

/dts-v1/;
#include <arm/rafael/rt584.dtsi>

/ {
    model = "Rafael Microelectronics RT584 EVB";
    compatible = "rafael,rt584-evb", "rafael,rt584";

    chosen {
        zephyr,sram             = &sram0;
        zephyr,flash            = &flash0;
        zephyr,flash-controller = &flash_controller;
        zephyr,console          = &uart0;
        zephyr,shell-uart       = &uart0;
        zephyr,code-partition   = &slot0_partition;
    };
};
