# Zephyr sets SOC_RT584 automatically via board.yml / soc.yml.
# Only set application-level configs here.

# Console via UART0 (GPIO17=TX, GPIO16=RX, 115200 baud)
CONFIG_SERIAL=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_RT584=y

# Generate Intel HEX — convenient for openocd flash loading.
CONFIG_BUILD_OUTPUT_HEX=y
