# Zephyr sets SOC_RT583 automatically via board.yml / soc.yml.
# Only set application-level configs here.

# Console via UART0 (GPIO16=TX, GPIO17=RX, 115200 baud)
CONFIG_SERIAL=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_RT583=y

# Entropy subsystem — required for ENTROPY_RT583 (TRNG driver) and BLE/OT CSPRNG
CONFIG_ENTROPY_GENERATOR=y
