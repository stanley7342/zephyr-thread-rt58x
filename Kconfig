# Top-level Kconfig for rt582-zephyr-helloworld.
# Zephyr's Kconfig tree is sourced first, then we add our custom driver.

osource "$(ZEPHYR_BASE)/Kconfig"

# Include the RT582 UART driver Kconfig so CONFIG_UART_RT582 is visible.
rsource "drivers/serial/Kconfig"

# OpenThread
config OPENTHREAD_RT582
    bool "OpenThread for Rafael RT582"
    depends on SOC_RT582
    help
      Enables the OpenThread stack on the RT582 SoC.
      Links the pre-built Rafael SDK OpenThread FTD library and the
      RT582-specific Zephyr platform layer (replaces FreeRTOS with
      Zephyr kernel primitives).

if OPENTHREAD_RT582

menu "RT582 IEEE 802.15.4 PHY/MAC PIB"

config RT582_PHY_PIB_TURNAROUND_TIMER
    int "PHY turnaround time (symbols)"
    default 192

config RT582_PHY_PIB_CCA_DETECTED_TIME
    int "PHY CCA detected time (symbols)"
    default 128

config RT582_PHY_PIB_CCA_DETECT_MODE
    int "PHY CCA detection mode (0=ED, 1=CS, 2=ED+CS)"
    default 0
    range 0 2

config RT582_PHY_PIB_CCA_THRESHOLD
    int "PHY CCA energy threshold"
    default 85

config RT582_MAC_PIB_UNIT_BACKOFF_PERIOD
    int "MAC unit backoff period (symbols)"
    default 320

config RT582_MAC_PIB_ACK_WAIT_DURATION
    int "MAC ACK wait duration (symbols)"
    default 544

config RT582_MAC_PIB_MAX_BE
    int "MAC maximum backoff exponent"
    default 8
    range 0 8

config RT582_MAC_PIB_MAX_FRAME_TOTAL_WAIT_TIME
    int "MAC max frame total wait time (symbols)"
    default 16416

config RT582_MAC_PIB_MAX_FRAME_RETRIES
    int "MAC max frame retries"
    default 4
    range 0 7

config RT582_MAC_PIB_MAX_CSMACA_BACKOFFS
    int "MAC max CSMA-CA backoffs"
    default 10
    range 0 10

config RT582_MAC_PIB_MIN_BE
    int "MAC minimum backoff exponent"
    default 5
    range 0 8

endmenu

endif # OPENTHREAD_RT582
