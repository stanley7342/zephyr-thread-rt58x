config FLASH_RT582
    bool "Rafael RT582 internal flash driver"
    depends on SOC_SERIES_RT582
    select FLASH_HAS_DRIVER_ENABLED
    select FLASH_HAS_PAGE_LAYOUT
    default y
    help
      Flash driver for Rafael RT582 internal SPI flash.
      Wraps the HOSAL/flashctl API into Zephyr flash_driver_api.
      Supports 4KB sector erase and 256-byte page writes.
